/* app.wxss - 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 状态标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}
.tag-free { background: #e8f5e9; color: #4CAF50; }
.tag-busy { background: #fff3e0; color: #FF9800; }
.tag-fault { background: #fce4ec; color: #E91E63; }
.tag-offline { background: #f5f5f5; color: #9E9E9E; }

/* 主色按钮 */
.btn-primary {
  background: #4CAF50;
  color: #fff;
  border-radius: 50rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 32rpx;
  border: none;
}
.btn-primary:active { opacity: 0.85; }

.btn-outline {
  background: transparent;
  color: #4CAF50;
  border: 2rpx solid #4CAF50;
  border-radius: 50rpx;
  padding: 18rpx 0;
  text-align: center;
  font-size: 32rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}
.empty image { width: 160rpx; height: 160rpx; margin-bottom: 20rpx; }

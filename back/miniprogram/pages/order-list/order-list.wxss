.tabs { display: flex; background: #fff; border-bottom: 1rpx solid #f0f0f0; }
.tab { flex: 1; text-align: center; padding: 24rpx 0; font-size: 26rpx; color: #666; }
.tab.active { color: #4CAF50; border-bottom: 4rpx solid #4CAF50; font-weight: bold; }
.list { height: calc(100vh - 100rpx); }
.order-card { margin: 16rpx 20rpx; }
.order-header { display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.station-name { font-size: 30rpx; font-weight: bold; }
.status { font-size: 26rpx; }
.order-info { display: flex; justify-content: space-between; color: #666; font-size: 26rpx; margin-bottom: 8rpx; }
.order-time { font-size: 22rpx; color: #999; }

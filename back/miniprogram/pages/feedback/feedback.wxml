<view class="feedback-page">
  <view class="tabs">
    <view class="tab {{activeTab===0?'active':''}}" bindtap="onTabChange" data-idx="0">提交反馈</view>
    <view class="tab {{activeTab===1?'active':''}}" bindtap="onTabChange" data-idx="1">我的反馈</view>
  </view>

  <!-- 提交表单 -->
  <view wx:if="{{activeTab===0}}" class="container">
    <view class="card">
      <view class="form-row">
        <text class="form-label">充电站ID</text>
        <input placeholder="请输入充电站ID" value="{{stationId}}" bindinput="onStationInput" type="number"/>
      </view>
      <view class="form-row">
        <text class="form-label">反馈类型</text>
        <picker range="{{typeOptions}}" bindchange="onTypeChange">
          <text>{{typeOptions[baoxuiTypes-1]}} ›</text>
        </picker>
      </view>
      <view class="form-row">
        <text class="form-label">问题描述</text>
        <textarea placeholder="请描述问题..." value="{{baoxuiContent}}" bindinput="onContentInput" class="textarea"/>
      </view>
      <view class="photo-area">
        <text class="form-label">上传照片（最多3张）</text>
        <view class="photo-list">
          <image wx:for="{{photos}}" wx:key="index" src="{{item}}" mode="aspectFill" class="photo-item" bindtap="removePhoto" data-idx="{{index}}"/>
          <view wx:if="{{photos.length < 3}}" class="add-photo" bindtap="choosePhoto">+</view>
        </view>
      </view>
    </view>
    <view class="tip card">审核通过后将获得 50 积分奖励 🎁</view>
    <button class="btn-primary" bindtap="onSubmit">提交反馈</button>
  </view>

  <!-- 我的反馈列表 -->
  <view wx:if="{{activeTab===1}}" class="container">
    <view wx:for="{{myList}}" wx:key="id" class="feedback-item card">
      <view class="fb-header">
        <text class="fb-name">{{item.baoxuiName}}</text>
        <text class="tag {{item.baoxuiZhuangtaiTypes===2?'tag-free':'tag-busy'}}">
          {{item.baoxuiZhuangtaiTypes===2?'已处理':'待处理'}}
        </text>
      </view>
      <text class="fb-content">{{item.baoxuiContent}}</text>
      <text class="fb-time">{{item.createTime}}</text>
    </view>
    <view wx:if="{{myList.length===0}}" class="empty">暂无反馈记录</view>
  </view>
</view>

.profile-page { background: #f5f5f5; min-height: 100vh; }
.user-header { background: linear-gradient(135deg, #4CAF50, #2E7D32); padding: 60rpx 40rpx; display: flex; align-items: center; gap: 30rpx; }
.user-avatar-placeholder { width: 120rpx; height: 120rpx; border-radius: 50%; background: rgba(255,255,255,0.3); display: flex; align-items: center; justify-content: center; font-size: 52rpx; color: #fff; font-weight: bold; flex-shrink: 0; }
.user-name { color: #fff; font-size: 36rpx; font-weight: bold; display: block; }
.user-phone { color: rgba(255,255,255,0.8); font-size: 26rpx; }
.stats-row { display: flex; margin: 20rpx; padding: 30rpx; }
.stat-item { flex: 1; text-align: center; }
.stat-divider { width: 1rpx; background: #f0f0f0; margin: 10rpx 0; }
.stat-val { font-size: 40rpx; font-weight: bold; color: #333; display: block; }
.stat-label { font-size: 24rpx; color: #999; }
.menu-list { margin: 0 20rpx; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 0; border-bottom: 1rpx solid #f0f0f0; font-size: 30rpx; }
.menu-item:last-child { border-bottom: none; }
.arrow { color: #ccc; font-size: 36rpx; }
.logout-btn { margin: 40rpx 20rpx; background: #fff; color: #F44336; border: 1rpx solid #F44336; border-radius: 50rpx; }

.contact-btn { background: transparent; border: none; padding: 0; margin: 0; line-height: normal; font-size: 30rpx; border-radius: 0; }
.contact-btn::after { border: none; }

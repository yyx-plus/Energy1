.detail-page { background: #f5f5f5; }
.station-photo { width: 100%; height: 400rpx; display: block; }
.info-card { margin: 20rpx; }
.info-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12rpx; }
.station-name { font-size: 36rpx; font-weight: bold; flex: 1; }
.navigate-btn { background: #e8f5e9; color: #4CAF50; padding: 10rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; white-space: nowrap; }
.station-addr { font-size: 26rpx; color: #999; display: block; margin-bottom: 16rpx; }
.price-row { display: flex; align-items: center; gap: 16rpx; }
.price-label { font-size: 26rpx; color: #666; }
.price-value { font-size: 26rpx; color: #FF9800; }
.section-title { padding: 16rpx 30rpx 8rpx; font-size: 30rpx; font-weight: bold; }
.section-title-inline { font-size: 30rpx; font-weight: bold; margin-bottom: 16rpx; }
.gun-item { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.gun-item:last-child { border-bottom: none; }
.gun-info { flex: 1; }
.gun-name { font-size: 28rpx; display: block; }
.gun-power { font-size: 24rpx; color: #999; }
.gun-right { display: flex; align-items: center; gap: 16rpx; }
.reserve-btn { background: #4CAF50; color: #fff; font-size: 24rpx; padding: 8rpx 24rpx; border-radius: 30rpx; border: none; margin: 0; }
.price-chart-card { overflow: hidden; }
.price-scroll { width: 100%; }
.price-bars { display: flex; align-items: flex-end; padding: 20rpx 0; min-width: 1200rpx; }
.price-bar-item { display: flex; flex-direction: column; align-items: center; width: 50rpx; margin: 0 4rpx; }
.bar-wrap { height: 120rpx; display: flex; align-items: flex-end; }
.bar { width: 36rpx; border-radius: 4rpx 4rpx 0 0; min-height: 10rpx; }
.period-1 { background: #F44336; }
.period-2 { background: #FF9800; }
.period-3 { background: #4CAF50; }
.period-4 { background: #2196F3; }
.bar-price { font-size: 18rpx; color: #666; margin-top: 4rpx; }
.bar-hour { font-size: 18rpx; color: #999; }
.price-legend { display: flex; gap: 24rpx; margin-top: 16rpx; justify-content: center; }
.legend-item { display: flex; align-items: center; gap: 8rpx; font-size: 22rpx; color: #666; }
.legend-dot { width: 20rpx; height: 20rpx; border-radius: 50%; }

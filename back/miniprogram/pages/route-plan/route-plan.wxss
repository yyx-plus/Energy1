.input-row { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.input-row:last-child { border-bottom: none; }
.input-label { color: #666; font-size: 28rpx; width: 160rpx; }
.input-val { flex: 1; text-align: right; font-size: 28rpx; }
.placeholder { color: #ccc; }
.range-input { display: flex; align-items: center; gap: 10rpx; }
.num-input { width: 120rpx; text-align: right; font-size: 28rpx; border-bottom: 1rpx solid #ddd; }
.result-summary { display: flex; justify-content: space-between; align-items: center; }
.need-charge { color: #FF9800; }
.no-charge { color: #4CAF50; }
.s-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.s-name { font-size: 30rpx; font-weight: bold; }
.s-addr { font-size: 24rpx; color: #999; display: block; margin-bottom: 12rpx; }
.s-stats { display: flex; gap: 24rpx; font-size: 24rpx; color: #666; }

.dest-btn { background: transparent; border: none; padding: 20rpx 0; margin: 0; border-bottom: 1rpx solid #f0f0f0; border-radius: 0; width: 100%; }
.dest-btn::after { border: none; }

<view class="index-page">
  <!-- 轮播图 -->
  <swiper class="banner" indicator-dots autoplay interval="3000" circular>
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <image src="{{item.value}}" mode="aspectFill" class="banner-img"/>
    </swiper-item>
  </swiper>

  <!-- 快捷入口 -->
  <view class="quick-entry card">
    <view class="entry-item" bindtap="goMap">
      <view class="entry-icon map-icon">📍</view>
      <text>找充电桩</text>
    </view>
    <view class="entry-item" bindtap="goRoute">
      <view class="entry-icon route-icon">🗺️</view>
      <text>路径补能</text>
    </view>
    <view class="entry-item" bindtap="goOrders">
      <view class="entry-icon order-icon">📋</view>
      <text>我的订单</text>
    </view>
    <view class="entry-item" bindtap="goFeedback">
      <view class="entry-icon feedback-icon">🔧</view>
      <text>故障反馈</text>
    </view>
  </view>

  <!-- 公告列表 -->
  <view class="section-title">最新公告</view>
  <view class="card">
    <view wx:for="{{notices}}" wx:key="id" class="notice-item" bindtap="goNoticeDetail" data-id="{{item.id}}">
      <text class="notice-name">{{item.gonggaoName}}</text>
      <text class="notice-time">{{item.insertTime}}</text>
    </view>
    <view wx:if="{{notices.length === 0}}" class="empty">暂无公告</view>
  </view>
</view>

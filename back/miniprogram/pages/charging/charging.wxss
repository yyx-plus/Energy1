.charging-page { min-height: 100vh; background: #f5f5f5; }
.phase-view { display: flex; flex-direction: column; align-items: center; padding: 80rpx 40rpx; }
.countdown-circle { width: 300rpx; height: 300rpx; border-radius: 50%; border: 8rpx solid #4CAF50; display: flex; flex-direction: column; align-items: center; justify-content: center; margin-bottom: 40rpx; }
.countdown-num { font-size: 72rpx; font-weight: bold; color: #4CAF50; }
.countdown-label { font-size: 24rpx; color: #999; }
.phase-tip { color: #666; font-size: 28rpx; margin-bottom: 60rpx; }
.start-btn { width: 560rpx; }
.charging { background: linear-gradient(180deg, #e8f5e9, #f5f5f5); }
.charging-anim { font-size: 120rpx; animation: pulse 1s infinite; margin-bottom: 20rpx; }
@keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.1)} }
.charging-time { font-size: 80rpx; font-weight: bold; color: #4CAF50; }
.charging-label { font-size: 26rpx; color: #999; margin-bottom: 40rpx; }
.charging-stats { width: 560rpx; display: flex; justify-content: center; margin-bottom: 60rpx; }
.stat-item { text-align: center; }
.stat-val { font-size: 48rpx; font-weight: bold; color: #333; display: block; }
.stat-label { font-size: 24rpx; color: #999; }
.stop-btn { width: 560rpx; }

.map-page { display: flex; flex-direction: column; height: 100vh; background: #f5f5f5; }

/* 搜索栏 */
.search-bar { display: flex; align-items: center; padding: 16rpx 20rpx; background: #fff; gap: 16rpx; z-index: 10; }
.search-input { flex: 1; background: #f5f5f5; border-radius: 40rpx; padding: 12rpx 24rpx; font-size: 28rpx; }
.search-btn { background: #4CAF50; color: #fff; padding: 12rpx 28rpx; border-radius: 40rpx; font-size: 26rpx; white-space: nowrap; }

/* 筛选标签 */
.filter-bar { display: flex; gap: 16rpx; padding: 10rpx 20rpx; background: #fff; border-bottom: 1rpx solid #f0f0f0; z-index: 10; }
.filter-tag { padding: 8rpx 24rpx; border-radius: 30rpx; border: 1rpx solid #ddd; font-size: 24rpx; color: #666; }
.filter-tag.active { background: #4CAF50; color: #fff; border-color: #4CAF50; }

/* 地图占满剩余空间 */
.map-view { width: 100%; height: 60vh; }

/* 底部站点列表 */
.station-list { flex: 1; background: #fff; border-top: 1rpx solid #eee; overflow-y: auto; }
.list-header { padding: 16rpx 24rpx 8rpx; font-size: 26rpx; color: #999; }

.station-item { display: flex; justify-content: space-between; align-items: center; margin: 0 20rpx 16rpx; padding: 20rpx; background: #fff; border-radius: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.station-info { flex: 1; overflow: hidden; }
.station-name { font-size: 30rpx; font-weight: bold; display: block; }
.station-addr { font-size: 24rpx; color: #999; display: block; margin: 6rpx 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.station-tags { display: flex; align-items: center; gap: 16rpx; margin-top: 8rpx; }
.price-text { font-size: 24rpx; color: #FF9800; }
.station-dist { text-align: right; color: #999; font-size: 24rpx; padding-left: 16rpx; flex-shrink: 0; }
.arrow { font-size: 36rpx; color: #ccc; display: block; }

/* 标签 */
.tag { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 20rpx; }
.tag-free { background: #e8f5e9; color: #4CAF50; }
.tag-busy { background: #fce4ec; color: #e53935; }
.tag-type { background: #e3f2fd; color: #1976D2; }
.tag-fast { background: #fff3e0; color: #ff9800; }
.tag-parking { background: #f3e5f5; color: #9c27b0; }
.empty { text-align: center; padding: 60rpx 0; color: #bbb; font-size: 28rpx; }

/* 地图点击弹出卡片 */
.station-popup { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 32rpx; box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.12); z-index: 100; }
.popup-close { position: absolute; top: 24rpx; right: 32rpx; font-size: 36rpx; color: #999; }
.popup-name { font-size: 34rpx; font-weight: bold; display: block; margin-bottom: 10rpx; }
.popup-addr { font-size: 26rpx; color: #999; display: block; margin-bottom: 16rpx; }
.popup-tags { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.popup-row { display: flex; align-items: center; gap: 20rpx; margin-bottom: 24rpx; }
.popup-price { color: #FF9800; font-size: 28rpx; }
.popup-btn { width: 100%; background: #4CAF50; color: #fff; border-radius: 50rpx; font-size: 30rpx; }
.btn-primary { background: #4CAF50; color: #fff; border-radius: 50rpx; }
.tag-type { background: #e3f2fd; color: #1976D2; }

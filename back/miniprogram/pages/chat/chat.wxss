.chat-page { display: flex; flex-direction: column; height: 100vh; background: #f0f0f0; }

.msg-list { flex: 1; padding: 20rpx; overflow-y: auto; }

.empty { text-align: center; color: #bbb; font-size: 28rpx; padding: 80rpx 0; }

.msg-group { margin-bottom: 30rpx; }

.bubble-row { display: flex; align-items: flex-end; margin-bottom: 16rpx; }

.user-row { flex-direction: row-reverse; }
.cs-row { flex-direction: row; }

.avatar { width: 72rpx; height: 72rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22rpx; flex-shrink: 0; }
.user-avatar { background: #4CAF50; color: #fff; margin-left: 16rpx; }
.cs-avatar { background: #2196F3; color: #fff; margin-right: 16rpx; font-size: 20rpx; }

.bubble { max-width: 60vw; padding: 20rpx 24rpx; border-radius: 20rpx; font-size: 28rpx; line-height: 1.5; word-break: break-all; }
.user-bubble { background: #4CAF50; color: #fff; border-bottom-right-radius: 4rpx; }
.cs-bubble { background: #fff; color: #333; border-bottom-left-radius: 4rpx; }

.pending-tip { font-size: 22rpx; color: #bbb; text-align: right; padding-right: 88rpx; margin-top: -8rpx; }

.input-bar { display: flex; align-items: center; padding: 16rpx 20rpx; background: #fff; border-top: 1rpx solid #eee; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); }
.msg-input { flex: 1; background: #f5f5f5; border-radius: 40rpx; padding: 16rpx 24rpx; font-size: 28rpx; }
.send-btn { margin-left: 16rpx; background: #4CAF50; color: #fff; border-radius: 40rpx; font-size: 28rpx; padding: 0 32rpx; height: 72rpx; line-height: 72rpx; }
